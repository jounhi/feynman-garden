---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`关于 - ${SITE_TITLE}`} description="关于我和这个博客" />
	</head>
	<body>
		<Header />
		<main>
			<article class="prose">
				<h1>关于</h1>

				<p>
					你好，我是 <strong>jounhi</strong>，一名热爱学习的开发者。
				</p>

				<p>
					这个博客叫<strong>费曼花园</strong>，名字源自物理学家理查德·费曼。
					他有一种独特的能力——把最复杂的物理概念用最平实的语言讲清楚。
					正如他所说："If you can't explain it simply, you don't understand it well enough."
				</p>

				<p>
					在这里，我会记录学习计算机科学、数学、物理和其他感兴趣领域时的思考与笔记。
					每一篇文章都是一次理解的尝试，把输入转化为输出，把模糊变成清晰。
				</p>

				<h2>关于这个网站</h2>
				<ul>
					<li>基于 <a href="https://astro.build/">Astro</a> 构建的静态站点</li>
					<li>文章使用 Markdown / MDX 编写</li>
					<li>源码托管在 <a href="https://github.com/jounhi/feynman-garden">GitHub</a></li>
					<li>通过 Vercel 自动部署</li>
				</ul>

				<h2>联系我</h2>
				<p>
					GitHub: <a href="https://github.com/jounhi">@jounhi</a>
				</p>
			</article>
		</main>
		<Footer />
	</body>
</html>
<style>
	.prose {
		max-width: 720px;
		margin: 0 auto;
		padding: 2em 0;
	}
	.prose h1 {
		font-size: 2.441em;
		margin: 0 0 0.75em;
	}
	.prose h2 {
		font-size: 1.563em;
		margin: 1.5em 0 0.5em;
	}
	.prose p {
		line-height: 1.7;
		margin-bottom: 1.25em;
		color: rgb(var(--gray-dark));
	}
	.prose ul {
		line-height: 1.7;
		color: rgb(var(--gray-dark));
		padding-left: 1.5em;
	}
	.prose li {
		margin-bottom: 0.5em;
	}
</style>
